{
  "title": "FastAPI Application Overview",
  "tags": ["fastapi", "python"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m", "15m"]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (QPS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (endpoint)",
          "legendFormat": "{{ endpoint }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate by Status Code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (status)",
          "legendFormat": "{{ status }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "none" },
          "custom": {
            "textMode": "value_and_name"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        }
      },
      "targets": [
        {
          "expr": "http_requests_total",
          "legendFormat": "All Endpoints",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Average Response Time by Endpoint",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])",
          "legendFormat": "Overall Avg",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "interval": "15s"
        },
        {
          "expr": "process_virtual_memory_bytes",
          "legendFormat": "Virtual",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 7,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "cputicks",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "CPU/sec",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "process_open_fds",
          "legendFormat": "Open FDs",
          "interval": "15s"
        },
        {
          "expr": "process_max_fds",
          "legendFormat": "Max FDs",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 9,
      "title": "LLM Inference Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_inference_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p95 - {{ model }}",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_inference_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p50 - {{ model }}",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 10,
      "title": "DB Connections",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "custom": {
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "db_connections",
          "legendFormat": "Active",
          "interval": "15s"
        }
      ]
    },
    {
      "id": 11,
      "title": "LLM Stream Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_stream_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p95 - {{ model }}",
          "interval": "15s"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_stream_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "p50 - {{ model }}",
          "interval": "15s"
        }
      ]
    }
  ]
}
